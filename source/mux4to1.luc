module mux4to1 (
    input a,
    input b,
    input c,
    input d,
    input sel1,
    input sel2,
    output out
) {
    mux2to1 m[3]
    
    always {
        m.sel[0] = sel1
        m.sel[1] = sel1
        m.sel[2] = sel2
        
        // Mux 1 and 2
        m.a[0] = a
        m.b[0] = b
        m.a[1] = c
        m.b[1] = d
        
        // Mux 3
        m.a[2] = m.out[0]
        m.b[2] = m.out[1]
        out = m.out[2]
    }
}