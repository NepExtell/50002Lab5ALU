testbench test_add_sub {
    add_and_sub adder
    
    const TEST_VALUES_ALU = $reverse(
        {
            c{32d0,          32d0,          6h00, c{32d0,          1b1,1b0,1b0}}, // 00 ADD 0+0
            c{32h7FFFFFFF,   32d1,          6h00, c{32h80000000,   1b0,1b1,1b1}}, // 01 ADD pos overflow
            c{32d7,          32d5,          6h01, c{32d2,          1b0,1b0,1b0}}, // 02 SUB 7-5
            c{32h80000000,   32d1,          6h01, c{32h7FFFFFFF,   1b0,1b1,1b0}}  // 03 SUB neg overflow
        }
    )
    
    test myTest {
        repeat(i, 4){
            adder.a      = TEST_VALUES_ALU[i][104:73]
            adder.b      = TEST_VALUES_ALU[i][72:41]
            adder.is_sub = TEST_VALUES_ALU[i][35]  // ALUFN[0]
            $tick()
            $assert(adder.out == TEST_VALUES_ALU[i][34:3])
            $assert(adder.z   == TEST_VALUES_ALU[i][2])
            $assert(adder.v   == TEST_VALUES_ALU[i][1])
            $assert(adder.n   == TEST_VALUES_ALU[i][0])
            $print("PASS test case: %d", i+1)
        }
    }
}